# Shared
NODE_ENV=development
PORT=5000

# Backend
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ecom
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
# Comma-separated list allowed for CORS. Include local + deployed frontend URLs.
CLIENT_URL=http://localhost:5173,https://your-frontend-project.vercel.app
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123

# Frontend (Vite)
# MUST point to deployed backend API base including /api suffix.
VITE_API_BASE_URL=https://your-backend-service.onrender.com/api
