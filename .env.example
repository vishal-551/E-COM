# Frontend (Vite) environment
# ------------------------------------------------
# API base URL consumed by src/utils/api.js.
#
# Notes:
# - Include `/api`.
# - No trailing slash.
# - In development, the frontend falls back to http://localhost:5000/api when this is unset.
# - In production, set this explicitly.

# Local development example:
VITE_API_BASE_URL=http://localhost:5000/api

# Production examples:
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_API_BASE_URL=https://api.shop.yourdomain.com/api
