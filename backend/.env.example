# Runtime
# ------------------------------------------------
NODE_ENV=development
PORT=5000

# MongoDB (required)
# ------------------------------------------------
# Local:
MONGO_URI=mongodb://127.0.0.1:27017/ecom
# Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT (required)
# ------------------------------------------------
# Use a long random secret (>= 32 chars recommended, required in production).
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=7d

# Frontend origin(s) for CORS (required: set at least one)
# ------------------------------------------------
# Single frontend origin:
CLIENT_URL=http://localhost:5173
# Optional comma-separated allowlist (for multiple domains/environments).
# CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
# Production examples:
# CLIENT_URL=https://www.yourdomain.com
# CLIENT_URLS=https://www.yourdomain.com,https://staging.yourdomain.com,https://admin.yourdomain.com

# Cloudinary (required for uploads)
# ------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional admin seed values
# ------------------------------------------------
# If SEED_ADMIN_EMAIL + SEED_ADMIN_PASSWORD are set, server startup can create the admin user.
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
