# Runtime
NODE_ENV=development
PORT=5000

# MongoDB
# Local example:
MONGO_URI=mongodb://127.0.0.1:27017/ecom
# Atlas example:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend origin(s) for CORS
# Set CLIENT_URL for a single origin, or CLIENT_URLS for a comma-separated allowlist.
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# CLIENT_URL=https://www.yourdomain.com
# Production multi-origin example:
# CLIENT_URLS=https://www.yourdomain.com,https://admin.yourdomain.com

# Cloudinary (required for admin image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional admin seeding (used on backend start and by seed script)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
